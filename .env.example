# Copy this file to `.env` on the server and fill in the real values.
# `.env` is ignored by git, so production credentials stay local to the server.

# Subfolder install example: https://your-domain.com/newwave
# If a subdomain points directly to this folder, use:
# APP_BASE_URL=https://newwave.your-domain.com
# APP_BASE_PATH=/
APP_BASE_URL=https://your-domain.com/newwave
APP_BASE_PATH=/newwave
APP_PROTOCOL=https

# Shared database settings for PHP and dialer.js
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=dialerwave

# Optional explicit PHP aliases (leave blank if you use DB_* above)
DIALERDB_HOST=
DIALERDB_USER=
DIALERDB_PASS=
DIALERDB_NAME=

# SMTP / PHPMailer
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_SECURE=tls
SMTP_FROM_EMAIL=no-reply@your-domain.com
SMTP_FROM_NAME=New Wave Dialer
